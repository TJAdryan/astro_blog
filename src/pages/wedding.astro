---
import Layout from "../layouts/BlogPost.astro";
---

<Layout
	title="A September Promise"
	description="The Wedding of Dominick and Sophio"
	ogImage="/img/wedding_kiss.jpg"
	pubDate={new Date("September 2025")}
	favicon="/wedding-favicon.svg"
	noindex={true}
>
	<div class="wedding-container">
		<!-- Decoration: Floating Hearts Background -->
		<div class="hearts-bg">
			<div class="heart x1"></div>
			<div class="heart x2"></div>
			<div class="heart x3"></div>
			<div class="heart x4"></div>
			<div class="heart x5"></div>
		</div>

		<div class="wedding-content">
			<div
				class="language-switch-container"
				style="text-align: center; margin-bottom: 2rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
			>
				<button id="lang-toggle" class="lang-btn">
					Read in Georgian / წაიკითხეთ ქართულად 🇬🇪
				</button>
				<button id="read-aloud" class="lang-btn">
					Read Aloud 🔊
				</button>
				<div
					id="voice-select-container"
					style="display: none; align-items: center;"
				>
					<select
						id="voice-select"
						style="padding: 10px; border-radius: 30px; border: 2px solid #d6336c; background: #fff; color: #c2255c; font-family: inherit;"
					>
						<option value="">Default Voice</option>
					</select>
				</div>
				<button
					id="heart-trigger"
					class="lang-btn"
					style="background: #fff0f5; border-color: #ff69b4;"
				>
					Send More Love ❤️
				</button>
			</div>

			<audio
				id="georgian-audio"
				src="/audio/georgian_wedding.mp3"
				preload="none"></audio>
			<audio
				id="english-audio"
				src="/audio/english_wedding_v2.mp3"
				preload="none"></audio>

			<h2 class="romantic-title" id="text-title">
				The Wedding of Dominick and Sophio
			</h2>

			<p class="intro-text" id="text-intro">
				It was a September day in Brooklyn that felt like a gift—the
				kind of weather where the sun is bright but the air is crisp,
				signaling the perfect start to something new. On this morning,
				the light seemed to shine specifically for Dominick and Sophio.
			</p>

			<div class="video-container relative" id="video-wrapper">
				<video
					id="wedding-video"
					loop
					playsinline
					class="wedding-video"
					poster="/favicon.svg"
				>
					<!-- Note: Using a placeholder poster or transparent if none provided. 
                             Ideally we'd extract a frame, but for now we rely on the overlay covering it. -->
					<source src="/video/wedding_video.mp4" type="video/mp4" />
					Your browser does not support the video tag.
				</video>

				<!-- Custom Overlay -->
				<div
					id="video-overlay"
					class="absolute inset-0 bg-black/60 flex flex-col items-center justify-center z-20 backdrop-blur-[2px]"
				>
					<h3
						class="text-white font-serif text-2xl md:text-3xl mb-8 drop-shadow-md tracking-wide"
					>
						Wedding Highlights
					</h3>
					<div class="flex flex-col md:flex-row gap-4">
						<button
							id="btn-silent"
							class="px-6 py-2 bg-white/20 hover:bg-white/30 text-white rounded-full border border-white/40 backdrop-blur-sm transition-all text-sm font-medium tracking-wider uppercase hover:scale-105"
						>
							Watch Silent
						</button>
						<button
							id="btn-music"
							class="px-6 py-2 bg-pink-600 hover:bg-pink-700 text-white rounded-full shadow-lg shadow-pink-600/30 transition-all text-sm font-bold tracking-wider uppercase hover:scale-105 flex items-center gap-2"
						>
							<span>With Music</span>
							<svg
								class="w-4 h-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
								></path><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
								></path></svg
							>
						</button>
					</div>
				</div>
			</div>

			<script is:inline>
				const video = document.getElementById("wedding-video");
				const overlay = document.getElementById("video-overlay");
				const btnSilent = document.getElementById("btn-silent");
				const btnMusic = document.getElementById("btn-music");

				function startVideo(muted) {
					video.muted = muted;
					video.play();
					video.controls = true; // Enable native controls once playing
					overlay.style.opacity = "0";
					setTimeout(() => {
						overlay.style.display = "none";
					}, 500); // Wait for fade out
				}

				if (btnSilent && btnMusic) {
					btnSilent.addEventListener("click", () => startVideo(true));
					btnMusic.addEventListener("click", () => startVideo(false));
				}

				// --- Proposal Video Controls ---
				const proposalVideo = document.getElementById("proposal-video");
				const proposalOverlay = document.getElementById("proposal-overlay");
				const btnPlayProposal = document.getElementById("btn-play-proposal");

				if (btnPlayProposal && proposalVideo && proposalOverlay) {
					btnPlayProposal.addEventListener("click", () => {
						proposalVideo.play();
						proposalVideo.controls = true;
						proposalOverlay.style.opacity = "0";
						setTimeout(() => {
							proposalOverlay.style.display = "none";
						}, 500);
					});
				}

				// --- Translation Logic ---
				const langBtn = document.getElementById("lang-toggle");
				let isGeorgian = false;
				const originalText = {};

				const georgianContent = {
					"heart-trigger": "გააგზავნე მეტი სიყვარული ❤️",
					"text-title": "დომინიკისა და სოფიოს ქორწილი",
					"text-intro":
						"ეს იყო სექტემბრის დღე ბრუკლინში, რომელიც საჩუქარს ჰგავდა - ისეთი ამინდი, როცა მზე კაშკაშებს, მაგრამ ჰაერი გრილია, რაც რაღაც ახლის იდეალურ დასაწყისს მოასწავებს. ამ დილას სინათლე თითქოს სპეციალურად დომინიკისა და სოფიოსთვის ანათებდა.",
					"text-p1":
						"ისინი დილით მივიდნენ მერიაში, მზად რომ ოფიციალურად გაეფორმებინათ თავიანთი კავშირი. სოფიო აბსოლუტურად ლამაზად გამოიყურებოდა, ასხივებდა ბედნიერებას, რომელიც ოთახს ანათებდა. მის გვერდით დგომისას, დომინიკი სიამაყისა და ერთგულების განსახიერება იყო; თვალს ვერ აშორებდა მას. ცერემონია იყო ინტიმური და ღრმად ამაღელვებელი. მოსამართლე, რომელიც ფიცს უძღვებოდა, იყო თბილი და კეთილგანწყობილი, რაც პროცესს ნამდვილი სიყვარულის ტონს აძლევდა.",
					"text-p2":
						"სოფიო სიყვარულით სავსე ვიწრო წრეში იყო. მისი ქალიშვილი ახლოს იდგა და მომენტის მოწმე იყო, სოფიოს დეიდასთან ერთად, რომელიც მტკიცე, მხარდამჭერ დასაყრდენს წარმოადგენდა. მისი მეგობარი ნატალი მეჯვარედ დადგა და დარწმუნდა, რომ ყველაფერი იდეალურად იყო. საინტერესოა, რომ ჩვეულებრივ მოლაპარაკე გვანცა იქ იყო, მაგრამ გასაკვირად ჩუმად - ალბათ მომენტის სიმძიმითა და სილამაზით იყო მოცული.",
					"text-p3":
						"ამ ნათელ დღეს მხოლოდ ერთი ჩრდილო აწვა: სოფიოს დედა შორს, თავის სამშობლოში - საქართველოში იყო და ვერ დაესწრო. თუმცა, მისი სული იგრძნობოდა იმ სიყვარულში, რომელსაც სოფიო ატარებდა.",
					"text-p4":
						'ფიცის წარმოთქმისა და ქაღალდებზე ხელმოწერის შემდეგ, წყვილი ბრუკლინის ჰაერზე გამოვიდა. ისინი ბრუკლინის ხიდთან ახლოს მდებარე პარკებისკენ გაემართნენ ფოტოების გადასაღებად. თითქოს ქალაქსაც სურდა ზეიმში ჩართვა. სადაც კი გაივლიდნენ, უცნობები ჩერდებოდნენ, სახე უნათდებოდათ. "დღეს იქორწინეთ?" ეკითხებოდნენ ხალხი, რასაც მაშინვე თბილი ღიმილი და გულწრფელი შეძახილები მოსდევდა: "გილოცავთ!" უცნობების კეთილგანწყობამ დღე კიდევ უფრო ჯადოსნური გახადა.',
					"text-p5":
						'ზეიმი მანჰეტენზე გაგრძელდა, როდესაც ისინი მატარებლით მე-14 ქუჩაზე გაემგზავრნენ. მე-8 ავენიუდან დასავლეთით მიმავალ გზაზე, გადაწყვიტეს სწრაფი წასახემსებლად პიცერიაში შეჩერებულიყვნენ. სიცილს ვერ იკავებდნენ კონტრასტზე - ისხდნენ ფორმალურ საქორწილო ტანსაცმელში, ქაღალდის თეფშებისა და ფლუორესცენტული განათების გარემოცვაში. დომინიკმა, რომელსაც სურდა ყველაფერი იდეალური ყოფილიყო, ჰკითხა სოფიოს, ხომ არ ამჯობინებდა უფრო მაღალი დონის ადგილს. მან იდეა მაშინვე უარყო და ღიმილით შეხედა მას. <span class="quote">"სანამ ჩვენ ერთად ვართ"</span>, - თქვა მან.',
					"text-p6":
						"მათ განაგრძეს გზა წყლისკენ, გაიარეს Meatpacking District-ი. რიყის ქვით მოპირკეთებული ქუჩები, რომლებიც დიდი ხანია მდიდარი ხალხის სასეირნო ადგილად იქცა, განსაცვიფრებელ ფონს ქმნიდა. სეირნობისას კიდევ უფრო მეტი კომპლიმენტი და ღიმილი მიიღეს მოდური ხალხისგან, რომლებიც მოხიბლულნი იყვნენ ბედნიერი წყვილით.",
					"text-p7":
						"საბოლოოდ მიაღწიეს Little Island-ს, ჰუძონზე მოტივტივე ახალ პარკს. აქ წრე გაფართოვდა. სოფიოს მეგობრები ირინკა და ორი გვანცა იქ იყვნენ საზეიმოდ. მისი მეგობარი თინაც კი სამსახურის შემდეგ გამოიქცა, რომ სიხარული არ გამოტოვებოდა. ისინი იცინოდნენ და ისვენებდნენ წყალთან, ტკბებოდნენ ჰორიზონტით და იმ მოლოდინით, რაც წინ ელოდათ.",
					"text-p8":
						"საღამოს დადგომასთან ერთად, დადგა გრანდიოზული ფინალის დრო: სადილი კრუიზზე.",
					"text-p9":
						"ნავზე ასვლის შემდეგ, წვეულება ნამდვილად დაიწყო. დომინიკის სამყარო შეერწყა სოფიოსას, როდესაც მისი მეგობრები ვენი, საბინა და პიტი ზეიმს შეუერთდნენ. ეს იყო ცხოვრებისეული შეკრება, რადგან დომინიკის ბავშვობის მეგობრები, ფუმიო და ჯეიმსი იქ იყვნენ. დომინიკი თავს ძალიან პატივცემულად გრძნობდა, რომ ჯეიმსის დედა, ჯუდი, შეძლო ზეიმზე დასწრება. მან წაახალისა დომინიკი ეცეკვა სოფიოსთან, თუმცა ეს არ არის ის, რაც მას ჩვეულებრივ სიამოვნებს. დომინიკმა ჭკვიანურად დაუჯერა ჯუდის. მოგვიანებით ის ისეთი ბედნიერი იყო, რომ დაუჯერა, რომ ჯუდი საცეკვაო მოედანზე მიიწვია და სამივემ რამდენიმე სიმღერაზე ერთად იცეკვა. ელიზაბეტიც კი, დომინიკის ყოფილი თანამშრომელი, მოვიდა საზეიმოდ; ის ყოველთვის იყო დომინიკისა და სოფიოს ურთიერთობის აქტიური მხარდამჭერი და მათი დაქორწინებულების ნახვა მისთვის განსაკუთრებული მომენტი იყო.",
					"text-p10":
						'ღამე სიხარულის ბუნდოვანებად იქცა. ისინი ჭამდნენ, სვამდნენ და საუბრობდნენ, სანამ ფანჯრებს მიღმა ქალაქის შუქები მიცურავდა. ენერგია მაღალი იყო, მაგრამ პიკს მიაღწია, როდესაც ბენდის ლიდერმა, ქარიზმატულმა ქალმა შთამბეჭდავი გარეგნობით, მიკროფონი აიღო. მან მუსიკა შეაჩერა და ხალხს ჰკითხა: "თქვენ ორმა დღეს იქორწინეთ?"',
					"text-p11":
						"როდესაც დომინიკმა და სოფიომ კი უპასუხეს, ოთახი აფეთქდა. ბენდმა სპეციალური საპატიო სიმღერა შეასრულა მხოლოდ მათთვის. ყველამ - ბავშვობის მეგობრებმა, თანამშრომლებმა, ოჯახმა და ახალმა ნაცნობებმა - წრე შეკრეს და ახალდაქორწინებულების გარშემო ცეკვავდნენ. ეს იყო შესანიშნავი საღამო, მშვიდი და თავდადებული სიყვარულის ხმამაღალი და მხიარული გამოცხადება.",
					"text-proposal-title": "ხელის თხოვნა",
					"text-proposal-desc":
						"სანამ ფიცს დავდებდით და აღვნიშნავდით, იყო ერთი ჩუმი დაპირება. სოფოს ხელის თხოვნა — ზუსტად ისე, როგორც მახსოვს.",
				};

				if (langBtn) {
					langBtn.addEventListener("click", () => {
						isGeorgian = !isGeorgian;
						// Hide/Show voice selector based on language
						const voiceContainer = document.getElementById(
							"voice-select-container",
						);
						if (voiceContainer) {
							// Always keep hidden as we are using pre-gen audio for both languages
							voiceContainer.style.display = "none";
						}

						const ids = Object.keys(georgianContent);

						ids.forEach((id) => {
							const el = document.getElementById(id);
							if (el) {
								if (!originalText[id])
									originalText[id] = el.innerHTML; // Save ENG

								if (isGeorgian) {
									el.innerHTML = georgianContent[id];
								} else {
									el.innerHTML = originalText[id];
								}
							}
						});

						langBtn.textContent = isGeorgian
							? "Read in English 🇺🇸"
							: "Read in Georgian / წაიკითხეთ ქართულად 🇬🇪";
					});
				}

				// --- Read Aloud Logic ---
				const readAloudBtn = document.getElementById("read-aloud");
				const audioPlayerGeo =
					document.getElementById("georgian-audio");
				const audioPlayerEng = document.getElementById("english-audio");
				const voiceSelect = document.getElementById("voice-select");
				const voiceContainer = document.getElementById(
					"voice-select-container",
				);

				// Initialize Voices
				// We are now using a specific pre-generated MP3 with dual voices (Christopher & Aria).
				// We no longer populate the dropdown with system voices to prevent confusion.
				function populateVoices() {
					// Intentional no-op
				}

				// Show voice selector initially if in English mode
				// HIDDEN: We want to force the use of the pre-generated MP3
				if (voiceContainer && !isGeorgian) {
					voiceContainer.style.display = "none";
				}

				const stopReading = () => {
					window.speechSynthesis.cancel();
					if (audioPlayerGeo) {
						audioPlayerGeo.pause();
						audioPlayerGeo.currentTime = 0;
					}
					if (audioPlayerEng) {
						audioPlayerEng.pause();
						audioPlayerEng.currentTime = 0;
					}
					if (readAloudBtn) {
						readAloudBtn.textContent = isGeorgian
							? "ხმამაღლა წაკითხვა 🔊"
							: "Read Aloud 🔊";
					}
				};

				if (langBtn) {
					langBtn.addEventListener("click", stopReading);
				}

				const idsToRead = [
					"text-title",
					"text-intro",
					"text-p1",
					"text-p2",
					"text-p3",
					"text-p4",
					"text-p5",
					"text-p6",
					"text-p7",
					"text-p8",
					"text-p9",
					"text-p10",
					"text-p11",
				];

				if (readAloudBtn) {
					readAloudBtn.addEventListener("click", () => {
						const synth = window.speechSynthesis;
						const isSpeakingEng =
							synth.speaking ||
							(audioPlayerEng && !audioPlayerEng.paused);
						const isSpeakingGeo =
							audioPlayerGeo && !audioPlayerGeo.paused;

						if (isSpeakingEng || isSpeakingGeo) {
							stopReading();
							return;
						}

						readAloudBtn.textContent = isGeorgian
							? "შეჩერება ⏹️"
							: "Stop Reading ⏹️";

						if (isGeorgian) {
							if (audioPlayerGeo) {
								audioPlayerGeo.play().catch((e) => {
									console.error("Audio play failed", e);
									alert("Could not play audio file.");
									stopReading();
								});
								audioPlayerGeo.onended = stopReading;
							}
						} else {
							// Try connecting to English Audio File
							// Strictly use the pre-generated MP3. No synthetic fallback.

							if (audioPlayerEng) {
								const playPromise = audioPlayerEng.play();

								if (playPromise !== undefined) {
									playPromise
										.then(() => {
											// Play started successfully
											audioPlayerEng.onended =
												stopReading;
										})
										.catch((error) => {
											console.error(
												"English audio file playback failed:",
												error,
											);
											alert("Could not play audio file.");
											stopReading();
										});
								}
							}
						}
					});
				}
