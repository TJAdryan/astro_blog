		}

		.falling-heart {
			position: absolute;
			top: -10vh;
			color: #ffb6c1; /* Light pink default */
			font-size: 1.5rem;
			opacity: 0.8;
			animation-name: fall, sway;
			animation-timing-function: linear, ease-in-out;
			animation-iteration-count: infinite, infinite;
		}

		@keyframes fall {
			0% {
				top: -10vh;
			}
			100% {
				top: 110vh;
			}
		}

		@keyframes sway {
			0% {
				transform: translateX(0px) rotate(0deg);
			}
			50% {
				transform: translateX(20px) rotate(10deg);
			}
			100% {
				transform: translateX(0px) rotate(0deg);
			}
		}
	</style>

	<div id="heart-rain-container"></div>

	<script is:inline>
		document.addEventListener("DOMContentLoaded", () => {
			const container = document.getElementById("heart-rain-container");
			if (!container) return;

			const colors = [
				"#ffb6c1",
				"#ff69b4",
				"#ff1493",
				"#db7093",
				"#ffa07a",
			]; // Pink/Red/Salmon variants

			const startTime = Date.now();
			const totalDuration = 15000; // 15 seconds

			function createHeart() {
				if (!container) return;

				const heart = document.createElement("div");
				heart.innerHTML = "❤";
				heart.classList.add("falling-heart");

				// Randomize properties
				const startLeft = Math.random() * 100; // 0 to 100 vw
				const durationFall = Math.random() * 5 + 5; // 5 to 10s
				const durationSway = Math.random() * 2 + 2; // 2 to 4s
				const scaleFactor = 2.5; // Significantly larger hearts
				const size = (Math.random() * 1.5 + 0.8) * scaleFactor;
				const color = colors[Math.floor(Math.random() * colors.length)];

				heart.style.left = `${startLeft}vw`;
				heart.style.animationDuration = `${durationFall}s, ${durationSway}s`;
				heart.style.fontSize = `${size}rem`;
				heart.style.color = color;

				container.appendChild(heart);

				// Cleanup this heart individually (no respawn logic here)
				setTimeout(() => {
					heart.remove();
				}, durationFall * 1000);
			}

			// Loop with increasing delay to create "Fade to Trickle" effect
			function spawnLoop() {
				const elapsed = Date.now() - startTime;
				if (elapsed > totalDuration) {
					// End sequence: Fade out container
					if (container) {
						container.style.transition = "opacity 2s ease-out";
						container.style.opacity = "0";
						setTimeout(() => container.remove(), 2000);
					}
					return;
				}

				// Calculate delay based on time (Quadratic/Power curve)
				// Start: ~30ms delay (very fast)
				// End: ~800ms delay (trickle)
				const progress = elapsed / totalDuration;
				const nextDelay = 30 + 1000 * Math.pow(progress, 2.5);

				createHeart();
				setTimeout(spawnLoop, nextDelay);
			}

			// Start the main loop
			spawnLoop();

			// Initial Burst to fill the screen immediately
			for (let i = 0; i < 20; i++) {
				setTimeout(createHeart, Math.random() * 1000);
			}

			// Manual Heart Trigger
			const heartTrigger = document.getElementById("heart-trigger");
			if (heartTrigger) {
				heartTrigger.addEventListener("click", () => {
					// Ensure container is active
					if (container) {
						// If it was removed or hidden, revive it
						if (!container.isConnected) {
							document.body.appendChild(container);
						}
						container.style.display = "block";
						container.style.transition = "none";
						container.style.opacity = "1";

						// Trigger a burst
						for (let i = 0; i < 30; i++) {
							setTimeout(createHeart, Math.random() * 800);
						}
					}
				});
			}
		});
	</script>
