---
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "fs";
import path from "path";
import { google } from "googleapis";

// Let Astro know to render this dynamically
export const prerender = false;

const DOCUMENT_ID = "1T7ytVl8r9sWkcEp5HxfVuN8p3YRIvGcFTaZMYefG0mw";
let dreams = [];

try {
    let credentialsStr = process.env.GOOGLE_SERVICE_ACCOUNT_JSON;

    // Fallback for local development if process.env isn't populated yet
    if (!credentialsStr) {
        try {
            const envPath = path.resolve(process.cwd(), ".env");
            const env = fs.readFileSync(envPath, "utf8");
            env.split("\n").forEach((line) => {
                if (line.startsWith("GOOGLE_SERVICE_ACCOUNT_JSON=")) {
                    credentialsStr = line.substring(
                        "GOOGLE_SERVICE_ACCOUNT_JSON=".length,
                    );
                    if (
                        credentialsStr.startsWith("'") &&
                        credentialsStr.endsWith("'")
                    ) {
                        credentialsStr = credentialsStr.substring(
                            1,
                            credentialsStr.length - 1,
                        );
                    }
                }
            });
        } catch (e) {
            console.error("Could not read local env", e);
        }
    }

    if (credentialsStr) {
        const credentials = JSON.parse(credentialsStr);
        const auth = new google.auth.GoogleAuth({
            credentials,
            scopes: ["https://www.googleapis.com/auth/documents"],
        });
        const docs = google.docs({ version: "v1", auth });

        const doc = await docs.documents.get({ documentId: DOCUMENT_ID });
        const textNodes = doc.data.body.content.map(
            (c) =>
                c.paragraph?.elements
                    ?.map((e) => e.textRun?.content || "")
                    .join("") || "",
        );

        const text = textNodes.join("");
        const chunks = text
            .split("---")
            .map((c) => c.trim())
            .filter(Boolean);

        for (const chunk of chunks) {
            // Match our [YYYY-MM-DDTHH:mm:SS.sssZ] <dream> pattern
            const match = chunk.match(/^\[(.*?)\]\s*([\s\S]*)$/);
            if (match) {
                // Ignore the "Hello from test!" messages if they don't match the regex but they usually won't
                dreams.push({
                    date: match[1],
                    dream: match[2].trim(),
                });
            }
        }
    }
} catch (e) {
    console.error("Error parsing abyss log from Google Docs", e);
}

// Ensure newest are at the top (it's inserted at index 1 so they actually prepend anyway,
// but they'll naturally be output top-down in the doc, meaning the newest is already first)
// Let's not reverse here if we read top-down. Wait, it inserts at index 1:
// Day 1 at index 1
// Day 2 at index 1 -> pushes Day 1 down
// So the parsing top-down will get newest first automatically!
---

<BaseLayout
    title="The Abyss - NextValData"
    description="Fevered dreams of missing pages."
    mainClass="max-w-3xl"
>
    <div class="abyss-container">
        <h1 class="abyss-title">The Abyss</h1>
        <p class="abyss-subtitle">
            A repository of fevered dreams and forgotten schemas.
        </p>

        <div class="dreams-list">
            {
                dreams.length === 0 ? (
                    <div class="empty-state">
                        The abyss is currently empty. No fevered dreams have
                        been recorded yet.
                    </div>
                ) : (
                    dreams.map((entry) => (
                        <div class="dream-card">
                            <div class="dream-date">
                                {new Date(entry.date).toLocaleString()}
                            </div>
                            <div class="dream-content">{entry.dream}</div>
                        </div>
                    ))
                )
            }
        </div>

        <a href="/" class="home-button">Return to Sanity</a>
    </div>

    <style>
        .abyss-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 4rem 1rem;
            min-height: 80vh;
            color: #cbd5e1;
            position: relative;
        }

        /* Ambient background smoke effect */
        .abyss-container::before,
        .abyss-container::after {
            content: "";
            position: fixed;
            top: -50%;
            left: -50%;
            right: -50%;
            bottom: -50%;
            pointer-events: none;
            z-index: -1;
        }

        .abyss-container::before {
            background: radial-gradient(
                circle at 50% 50%,
                rgba(15, 23, 42, 0) 0%,
                rgba(2, 6, 23, 0.9) 100%
            );
        }

        .abyss-container::after {
            background-image:
                radial-gradient(
                    circle at 30% 40%,
                    rgba(76, 29, 149, 0.15) 0%,
                    transparent 40%
                ),
                radial-gradient(
                    circle at 70% 60%,
                    rgba(20, 83, 45, 0.1) 0%,
                    transparent 40%
                ),
                radial-gradient(
                    circle at 50% 20%,
                    rgba(30, 58, 138, 0.15) 0%,
                    transparent 50%
                );
            filter: blur(80px);
            animation: smoke-drift 20s infinite alternate linear;
        }

        @keyframes smoke-drift {
            0% {
                transform: rotate(0deg) scale(1);
            }
            100% {
                transform: rotate(5deg) scale(1.1);
            }
        }

        .abyss-title {
            font-size: 3.5rem;
            font-weight: 300;
            margin-bottom: 0.5rem;
            color: #f1f5f9;
            letter-spacing: 0.15em;
            text-shadow:
                0 0 20px rgba(255, 255, 255, 0.3),
                0 0 40px rgba(139, 92, 246, 0.2);
            animation: pulse-glow 5s ease-in-out infinite alternate;
        }

        :global(.dark) .abyss-title {
            color: #f8fafc;
        }

        @keyframes pulse-glow {
            from {
                text-shadow:
                    0 0 20px rgba(255, 255, 255, 0.2),
                    0 0 40px rgba(139, 92, 246, 0.1);
            }
            to {
                text-shadow:
                    0 0 30px rgba(255, 255, 255, 0.5),
                    0 0 60px rgba(139, 92, 246, 0.4);
            }
        }

        .abyss-subtitle {
            font-size: 1.1rem;
            color: #94a3b8;
            margin-bottom: 5rem;
            font-style: italic;
            letter-spacing: 0.05em;
            opacity: 0.7;
        }

        :global(.dark) .abyss-subtitle {
            color: #aaa;
        }

        .dreams-list {
            display: flex;
            flex-direction: column;
            gap: 2.5rem;
            width: 100%;
            max-width: 650px;
            margin-bottom: 4rem;
            z-index: 10;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 2rem;
            background: rgba(30, 41, 59, 0.3);
            backdrop-filter: blur(10px);
            border: 1px dashed rgba(148, 163, 184, 0.2);
            border-radius: 16px;
            color: #64748b;
            font-style: italic;
        }

        :global(.dark) .empty-state {
            background: rgba(30, 41, 59, 0.3);
            border-color: rgba(148, 163, 184, 0.2);
            color: #64748b;
        }

        .dream-card {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(12px);
            padding: 2.5rem;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            box-shadow:
                0 10px 40px rgba(0, 0, 0, 0.4),
                inset 0 0 20px rgba(255, 255, 255, 0.01);
            transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
            animation: float 8s ease-in-out infinite;
        }

        .dream-card:nth-child(odd) {
            animation-delay: -3s;
        }

        .dream-card:nth-child(even) {
            animation-delay: -6s;
        }

        @keyframes float {
            0%,
            100% {
                transform: translateY(0) scale(1);
            }
            50% {
                transform: translateY(-12px) scale(1.01);
            }
        }

        .dream-card:hover {
            background: rgba(30, 41, 59, 0.6);
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow:
                0 20px 50px rgba(0, 0, 0, 0.6),
                0 0 40px rgba(76, 29, 149, 0.3);
            transform: translateY(-5px) scale(1.02);
            animation-play-state: paused;
        }

        :global(.dark) .dream-card {
            background: rgba(15, 23, 42, 0.4);
            box-shadow:
                0 10px 40px rgba(0, 0, 0, 0.4),
                inset 0 0 20px rgba(255, 255, 255, 0.01);
        }

        .dream-date {
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 1.2rem;
            font-family: monospace;
            opacity: 0.6;
            letter-spacing: 0.05em;
        }

        .dream-content {
            font-size: 1.15rem;
            line-height: 1.8;
            color: #cbd5e1;
            white-space: pre-wrap;
            font-weight: 300;
        }

        :global(.dark) .dream-content {
            color: #cbd5e1;
        }

        .home-button {
            display: inline-block;
            background: transparent;
            color: #94a3b8;
            padding: 0.8rem 2.5rem;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 300;
            font-size: 1.1rem;
            border: 1px solid rgba(148, 163, 184, 0.2);
            transition: all 0.4s ease;
            position: relative;
            z-index: 10;
        }

        .home-button:hover {
            color: #f1f5f9;
            border-color: rgba(255, 255, 255, 0.4);
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 30px rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
    </style>
</BaseLayout>
