---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="container">
    <div class="text-left mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight mb-2">My Reading List</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        A curated archive of seminal research papers, academic literature, books, and reference documentation that I read and study.
      </p>
    </div>

    <!-- Search & Filter Controls -->
    <div class="controls-container mb-8">
      <!-- Search Input -->
      <div class="search-wrapper">
        <input
          type="text"
          id="reading-search"
          class="search-input"
          placeholder="Search papers, authors, categories..."
          autocomplete="off"
        />
      </div>

      <!-- Category Filter Pills -->
      <div class="categories-wrapper" id="categories-filter">
        <!-- Will be dynamically populated with category pills -->
      </div>
    </div>

    <!-- Articles Grid -->
    <div id="articles-grid" class="articles-grid-container">
      <!-- All articles will be rendered dynamically here -->
    </div>
    <div id="no-results" class="no-results-message hidden">
      No reading list items match your search or filter criteria.
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    let allArticles = [];
    let selectedCategory = 'All';
    let searchQuery = '';

    const grid = document.getElementById('articles-grid');
    const filterContainer = document.getElementById('categories-filter');
    const searchInput = document.getElementById('reading-search');
    const noResults = document.getElementById('no-results');

    fetch('/data/articles.json')
      .then(res => res.json())
      .then(articles => {
        allArticles = articles;
        
        // 1. Extract unique categories (areas)
        const categories = new Set();
        articles.forEach(art => {
          if (art.area) categories.add(art.area);
        });

        // 2. Render filter pills
        renderFilterPills(Array.from(categories).sort());

        // 3. Initial render
        renderArticles();

        // 4. Setup search event listener
        if (searchInput) {
          searchInput.addEventListener('input', (e) => {
            searchQuery = e.target.value.toLowerCase();
            renderArticles();
          });
        }
      })
      .catch(err => {
        if (grid) {
          grid.innerHTML = '<p class="text-gray-500 text-center py-8">Unable to load the reading list.</p>';
        }
        console.error('Failed to load articles.json', err);
      });

    function getDomain(urlStr) {
      try {
        const hostname = new URL(urlStr).hostname;
        return hostname.replace(/^www\./, '');
      } catch (e) {
        return 'external resource';
      }
    }

    function getCategoryClass(area) {
      const norm = (area || '').toLowerCase();
      if (norm.includes('ai') || norm.includes('machine learning')) return 'badge-ai';
      if (norm.includes('database')) return 'badge-db';
      if (norm.includes('distributed')) return 'badge-dist';
      if (norm.includes('social')) return 'badge-social';
      if (norm.includes('economics')) return 'badge-econ';
      if (norm.includes('genomics') || norm.includes('crispr')) return 'badge-crispr';
      if (norm.includes('software') || norm.includes('engineering')) return 'badge-se';
      return 'badge-default';
    }

    function renderFilterPills(categoriesList) {
      if (!filterContainer) return;
      filterContainer.innerHTML = '';

      // Add 'All' pill
      const allPill = document.createElement('button');
      allPill.className = 'category-pill active';
      allPill.textContent = 'All';
      allPill.addEventListener('click', () => selectCategory('All', allPill));
      filterContainer.appendChild(allPill);

      categoriesList.forEach(cat => {
        const pill = document.createElement('button');
        pill.className = 'category-pill';
        pill.textContent = cat;
        pill.addEventListener('click', () => selectCategory(cat, pill));
        filterContainer.appendChild(pill);
      });
    }

    function selectCategory(cat, pillElement) {
      selectedCategory = cat;
      // Update active state in UI
      const pills = filterContainer.querySelectorAll('.category-pill');
      pills.forEach(p => p.classList.remove('active'));
      pillElement.classList.add('active');

      renderArticles();
    }

    function renderArticles() {
      if (!grid) return;
      grid.innerHTML = '';

      // Filter articles based on selectedCategory and searchQuery
      const filtered = allArticles.filter(art => {
        const matchCategory = selectedCategory === 'All' || art.area === selectedCategory;
        
        const textToSearch = [
          art.title,
          art.author,
          art.area,
          getDomain(art.url)
        ].join(' ').toLowerCase();
        
        const matchSearch = textToSearch.includes(searchQuery);

        return matchCategory && matchSearch;
      });

      if (filtered.length === 0) {
        if (noResults) noResults.classList.remove('hidden');
        return;
      }

      if (noResults) noResults.classList.add('hidden');

      filtered.forEach((art, index) => {
        const card = document.createElement('div');
        card.className = 'reading-card-item';
        card.style.animationDelay = `${index * 0.03}s`;

        const badgeClass = getCategoryClass(art.area);

        card.innerHTML = `
          <div class="card-meta">
            <span class="area-badge ${badgeClass}">${art.area || 'Resource'}</span>
            <span class="domain-badge">
              <svg style="width: 14px; height: 14px; margin-right: 4px; display: inline-block;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
              </svg>
              ${getDomain(art.url)}
            </span>
          </div>
          <h3 class="card-title">
            <a href="${art.url}" target="_blank" rel="noopener">
              ${art.title}
              <svg style="width: 14px; height: 14px; margin-left: 4px; display: inline-block;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </h3>
          <p class="card-author">By ${art.author || 'Unknown'}</p>
        `;

        grid.appendChild(card);
      });
    }
  });
</script>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Search input */
  .search-wrapper {
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: 0.85rem 1.35rem;
    font-size: 1.05rem;
    border: 2px solid transparent;
    border-radius: 50px;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(to right, #6366f1, #3b82f6) border-box; /* Cool blue/indigo gradient */
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.08);
    transition: all 0.3s ease;
    outline: none;
    color: #1e293b;
  }

  .search-input:focus {
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.18);
    transform: translateY(-1px);
  }

  /* Category pills */
  .categories-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .category-pill {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #e2e8f0;
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .category-pill:hover {
    background: #e2e8f0;
    color: #1e293b;
    transform: translateY(-1px);
  }

  .category-pill.active {
    background: #4f46e5;
    color: white;
    border-color: #4f46e5;
    box-shadow: 0 4px 10px rgba(99, 102, 241, 0.25);
  }

  /* Articles Grid */
  .articles-grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  @media (max-width: 640px) {
    .articles-grid-container {
      grid-template-columns: 1fr;
    }
  }

  /* Card Item */
  .reading-card-item {
    background: rgba(248, 250, 252, 0.55);
    border-left: 4px solid #6366f1;
    border-top: 1px solid rgba(99, 102, 241, 0.06);
    border-right: 1px solid rgba(99, 102, 241, 0.06);
    border-bottom: 1px solid rgba(99, 102, 241, 0.06);
    border-radius: 0 12px 12px 0;
    padding: 1.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.01);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    opacity: 0;
    transform: translateY(15px);
    animation: fadeInUp 0.4s ease-out forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reading-card-item:hover {
    transform: translateY(-2px) translateX(2px);
    background: white;
    box-shadow: 0 12px 20px rgba(99, 102, 241, 0.06);
    border-left-color: #ff6b35; /* Orange accent on hover to match brand */
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
  }

  .area-badge {
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Specific Badge Colors */
  .badge-ai { background-color: #f5f3ff; color: #7c3aed; border: 1px solid #ddd6fe; }
  .badge-db { background-color: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; }
  .badge-dist { background-color: #e0e7ff; color: #4f46e5; border: 1px solid #c7d2fe; }
  .badge-social { background-color: #fdf2f8; color: #db2777; border: 1px solid #fbcfe8; }
  .badge-econ { background-color: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
  .badge-crispr { background-color: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
  .badge-se { background-color: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
  .badge-default { background-color: #f8fafc; color: #475569; border: 1px solid #e2e8f0; }

  .domain-badge {
    display: inline-flex;
    align-items: center;
    color: #64748b;
    font-weight: 500;
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  .card-title a {
    color: #1e293b;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .card-title a:hover {
    color: #4f46e5;
  }

  .card-author {
    font-size: 0.92rem;
    font-style: italic;
    color: #64748b;
    margin: 0;
  }

  .no-results-message {
    font-size: 1.15rem;
    padding: 3rem 1rem;
    color: #64748b;
    text-align: center;
  }
  
  .hidden {
    display: none !important;
  }
</style>