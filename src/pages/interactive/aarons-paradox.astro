---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AaronsParadox from "../../components/AaronsParadox.tsx";
---

<BaseLayout title="Aaron's Paradox - Transmission vs. Competence" mainClass="max-w-5xl">
  <div class="py-6">
    <div class="mb-6">
      <a href="/interactive" class="text-accent hover:underline font-semibold flex items-center gap-1">
        ← Back to Interactive Gallery
      </a>
    </div>
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Aaron's Paradox</h1>
      <p class="text-slate-600 dark:text-slate-350 text-lg max-w-4xl leading-relaxed">
        Model transmission versus competence. Explore how filtering attention based on volume over validity structurally suppresses quiet experts in communication networks.
      </p>
    </div>
    <AaronsParadox client:only="react" />
  </div>
</BaseLayout>
