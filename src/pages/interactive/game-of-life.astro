---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ClimateGameOfLife from "../../components/ClimateGameOfLife.jsx";
---

<BaseLayout title="Ecosystem Cellular Automata - Game of Life" mainClass="max-w-5xl">
  <div class="py-6">
    <div class="mb-6">
      <a href="/interactive" class="text-accent hover:underline font-semibold flex items-center gap-1">
        ← Back to Interactive Gallery
      </a>
    </div>
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Ecosystem Cellular Automata</h1>
      <p class="text-slate-600 dark:text-slate-350 text-lg max-w-4xl leading-relaxed">
        A modified Conway's Game of Life simulation demonstrating non-linear feedback loops. Test systemic thresholds under varying temperature and resource stress.
      </p>
    </div>
    <ClimateGameOfLife client:only="react" />
  </div>
</BaseLayout>
