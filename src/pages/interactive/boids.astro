---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BoidsSimulation from "../../components/BoidsSimulation.tsx";
---

<BaseLayout title="Boids Flocking Simulation - Emergent Complexity" mainClass="max-w-5xl">
  <div class="py-6">
    <div class="mb-6">
      <a href="/interactive" class="text-accent hover:underline font-semibold flex items-center gap-1">
        ← Back to Interactive Gallery
      </a>
    </div>
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Boids Flocking</h1>
      <p class="text-slate-600 dark:text-slate-350 text-lg max-w-4xl leading-relaxed">
        Observe emergent complexity through three simple rules: Separation, Alignment, and Cohesion. Adjust steering vectors in real-time to guide the flock.
      </p>
    </div>
    <BoidsSimulation client:only="react" />
  </div>
</BaseLayout>
