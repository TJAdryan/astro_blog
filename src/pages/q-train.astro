---
import Layout from '../layouts/BaseLayout.astro';
import QTrainTracker from '../components/QTrainTracker.jsx';

const title = "BMT Brighton Line Status";
const description = "Real-time status updates for the Q and B trains on the BMT Brighton Line.";
---

<Layout title={title} description={description}>
  <main class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-center mb-8">{title}</h1>
    <div class="flex justify-center">
      <QTrainTracker client:load />
    </div>

    <!-- Dedicated Brighton Line History Banner Link -->
    <section class="mt-16 border-t border-slate-200 dark:border-slate-800 pt-12 max-w-md mx-auto">
      <div class="bg-gradient-to-br from-slate-50 to-white dark:from-slate-800/20 dark:to-slate-900/30 rounded-3xl p-6 border border-slate-200/60 dark:border-slate-800/80 shadow-md transition-all duration-300 hover:shadow-xl hover:scale-[1.01] group relative overflow-hidden">
        
        <!-- Subtle background decorative element representing subway line layout -->
        <div class="absolute -right-6 -bottom-6 w-32 h-32 rounded-full bg-[#FCCC0A]/5 dark:bg-[#FCCC0A]/3 border-8 border-[#FF6319]/10 group-hover:scale-110 transition-transform duration-500 pointer-events-none"></div>

        <div class="flex items-start gap-4">
          <!-- Styled transit bullet graphic -->
          <div class="w-12 h-12 rounded-full bg-slate-900 dark:bg-slate-800 flex items-center justify-center flex-shrink-0 shadow border border-slate-800 dark:border-slate-700">
            <span class="text-xl">⏱️</span>
          </div>

          <div class="flex-1 space-y-2">
            <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-[#FCCC0A]/10 dark:bg-[#FCCC0A]/15 text-slate-800 dark:text-[#FCCC0A] text-[10px] font-black uppercase tracking-wider border border-[#FCCC0A]/20">
              <span class="w-1.5 h-1.5 rounded-full bg-[#FCCC0A]"></span>
              <span>Corridor Legacy</span>
            </div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white tracking-tight leading-tight group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              Brighton Line History
            </h3>
            <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed font-medium">
              Explore the chronological history of the current Q/B corridor—from its origins in 1878 to municipal unification.
            </p>
            <div class="pt-2">
              <a 
                href="/brighton-history" 
                class="inline-flex items-center gap-1.5 text-sm font-black text-blue-600 dark:text-blue-400 group-hover:text-blue-800 dark:group-hover:text-blue-300"
              >
                Explore Timeline
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
