---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("stories")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const renderedPosts = await Promise.all(
	posts.map(async (post) => {
		const { Content } = await post.render();
		return { post, Content };
	})
);
---

<BaseLayout title="Stories" description="My Stories" noindex={true}>
	<section style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
		<h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 3rem; text-align: center; color: var(--accent);">Stories</h1>
		<div style="display: flex; flex-direction: column; gap: 4rem;">
			{
				renderedPosts.map(({ post, Content }) => (
					<article style="border-bottom: 1px solid #eaeaea; padding-bottom: 4rem;">
						<h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: capitalize;">
							{post.data.title}
						</h2>
						<div style="margin-bottom: 2rem; font-size: 0.9rem; color: #666; font-style: italic;">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<div class="prose prose-lg" style="line-height: 1.8; font-size: 1.1rem; color: #333;">
							<Content />
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
