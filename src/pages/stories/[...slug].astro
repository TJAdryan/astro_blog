---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection("stories");
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<"stories">;

const post = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} noindex={true} mainClass="max-w-4xl">
	<article class="prose max-w-none">
		<h1 class="text-4xl font-bold mb-2">{post.data.title}</h1>
		<div class="text-gray-500 mb-8 mt-2">
			<FormattedDate date={post.data.pubDate} />
		</div>
		<Content />
	</article>
</BaseLayout>
