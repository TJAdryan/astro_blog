---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/global.css";
import "../styles/custom.css";
import BaseHead from "../components/BaseHead.astro";
const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, favicon } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} image={image} favicon={favicon} />
  </head>
  <body class="min-h-screen bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-50">
    <div class="flex flex-col min-h-screen">
      <Header />
  <main class="flex-grow w-full" style="width:100vw;max-width:100vw;padding:0;margin:0;">
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline src="/js/dailyWidget.js" defer></script>
  </body>
</html>
