---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/global.css";
import "../styles/custom.css";

import BaseHead from "../components/BaseHead.astro";

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  mainClass = "max-w-3xl",
  noindex = false,
  image,
  favicon,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} image={image} favicon={favicon} noindex={noindex} />
  </head>
  <body
    class="min-h-screen bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-50"
  >
    <Header />
    <main class:list={[mainClass, "mx-auto px-4 py-8"]}>
      <slot />
      <!-- Your page content will go here -->
    </main>
    <Footer />
    <!-- Defer non-critical JavaScript for better performance -->
    <script is:inline src="/js/dailyWidget.js" defer></script>
  </body>
</html>
